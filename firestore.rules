rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (request.auth.token.email == 'm.painecura.g@gmail.com' || request.auth.token.email == 'dr.rodrigovallejos97@gmail.com'); 
    }
    
    function isValidVideoBlog(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.summary is string && data.summary.size() <= 5000 &&
             data.content is string &&
             data.imageUrl is string &&
             (!('instagramUrl' in data) || data.instagramUrl is string) &&
             data.createdAt is number && 
             data.updatedAt is number;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    match /videoBlogs/{blogId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(blogId) && isValidVideoBlog(incoming());
      allow update: if isAdmin() && isValidId(blogId) && isValidVideoBlog(incoming());
      allow delete: if isAdmin() && isValidId(blogId);
    }
  }
}
